class Solution {
    public boolean checkGoodInteger(int n) {
        int sum = 0;
        int sumsquare = 0;

        while (n > 0) {
            int digit = n % 10;
            sum += digit;
            sumsquare += digit * digit;
            n = n / 10;
        }

        int result = sumsquare - sum;

        return result >= 50;
    }
}
